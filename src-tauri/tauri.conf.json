{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "easy-agent-pilot",
  "version": "0.1.0",
  "identifier": "io.github.hyqf.agent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Easy Agent Pilot",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
